<?xml version="1.0" encoding="utf-8" ?>
<component name="SongSelect" extends="Group">
    <script type="text/brightscript" uri="pkg:/components/screens/SongSelect.brs" />

    <interface>
        <field id="songCatalog" type="assocarray" alwaysNotify="true" />
        <field id="selectedSong" type="assocarray" alwaysNotify="true" />
        <field id="action" type="string" alwaysNotify="true" />
    </interface>

    <children>
        <Rectangle id="bgBase" color="0x0a1628FF" />
        <Rectangle id="bgGradientTop" color="0x0d2137CC" />
        <Rectangle id="bgGradientBottom" color="0x162d50AA" />

        <Group id="sphereLayer">
            <Rectangle id="sphere1" color="0x2196F330" />
            <Rectangle id="sphere2" color="0x1565C025" />
            <Rectangle id="sphere3" color="0x42A5F520" />
            <Rectangle id="sphere4" color="0x0D47A128" />
            <Rectangle id="sphere5" color="0x1E88E518" />
        </Group>

        <Group id="headerGroup">
            <Rectangle id="headerBg" color="0x0a162880" />
            <Rectangle id="headerBorder" color="0x4FC3F720" />
            <Label id="headerTitle" text="SELECT A SONG" font="font:MediumBoldSystemFont"
                   color="0xE3F2FDDD" horizAlign="center" />
        </Group>

        <Group id="listPanel">
            <Rectangle id="listPanelBg" color="0xFFFFFF0A" />
            <Rectangle id="listPanelBorderTop" color="0xFFFFFF18" />
            <Rectangle id="listPanelBorderLeft" color="0xFFFFFF18" />
            <Rectangle id="listPanelBorderRight" color="0xFFFFFF08" />
            <Rectangle id="listPanelBorderBottom" color="0xFFFFFF08" />

            <Group id="songListContainer" />

            <Label id="scrollUpIndicator" text="▲" font="font:SmallBoldSystemFont"
                   color="0x4FC3F766" horizAlign="center" visible="false" />
            <Label id="scrollDownIndicator" text="▼" font="font:SmallBoldSystemFont"
                   color="0x4FC3F766" horizAlign="center" visible="false" />
        </Group>

        <Group id="detailsPanel">
            <Rectangle id="detailsPanelBg" color="0xFFFFFF0A" />
            <Rectangle id="detailsPanelBorderTop" color="0xFFFFFF18" />
            <Rectangle id="detailsPanelBorderLeft" color="0xFFFFFF18" />
            <Rectangle id="detailsPanelBorderRight" color="0xFFFFFF08" />
            <Rectangle id="detailsPanelBorderBottom" color="0xFFFFFF08" />

            <Group id="artworkGroup">
                <Rectangle id="artworkBg" color="0x1565C0FF" />
                <Rectangle id="artworkOverlay" color="0xFFFFFF08" />
                <Label id="artworkPlaceholder" text="♪" font="font:MediumBoldSystemFont"
                       color="0xFFFFFF44" horizAlign="center" vertAlign="center" />
            </Group>

            <Label id="detailTitle" text="Song Title" font="font:MediumBoldSystemFont"
                   color="0xFFFFFFEE" horizAlign="center" />

            <Label id="detailArtist" text="Artist" font="font:SmallSystemFont"
                   color="0xBBDEFBCC" horizAlign="center" />

            <Group id="difficultyRow">
                <Label id="difficultyLabel" text="Difficulty:" font="font:SmallSystemFont" color="0x90CAF9AA" />
                <Label id="difficultyValue" text="★★★☆☆" font="font:SmallSystemFont" color="0x4FC3F7FF" horizAlign="right" />
            </Group>

            <Group id="durationRow">
                <Label id="durationLabel" text="Duration:" font="font:SmallSystemFont" color="0x90CAF9AA" />
                <Label id="durationValue" text="0:00" font="font:SmallSystemFont" color="0xE3F2FDDD" horizAlign="right" />
            </Group>

            <Group id="bestScoreRow">
                <Label id="bestScoreLabel" text="Best Score:" font="font:SmallSystemFont" color="0x90CAF9AA" />
                <Label id="bestScoreValue" text="---" font="font:SmallSystemFont" color="0x4FC3F7FF" horizAlign="right" />
            </Group>

            <Group id="playButton">
                <Rectangle id="playBtnBg" color="0x1E88E5CC" />
                <Rectangle id="playBtnBorder" color="0x4FC3F730" />
                <Label id="playBtnLabel" text="▶  PLAY" font="font:SmallBoldSystemFont"
                       color="0xFFFFFFEE" horizAlign="center" vertAlign="center" />
            </Group>

            <Group id="qrSection">
                <Label id="qrLabel" text="Scan to play on phone" font="font:SmallestSystemFont"
                       color="0x90CAF966" horizAlign="center" />
                <Poster id="qrImage" uri="pkg:/images/qr_remote.png" />
            </Group>
        </Group>

        <Label id="instructions" text="↑↓ Navigate   |   OK Play   |   ← Back"
               font="font:SmallSystemFont" color="0x90CAF955" horizAlign="center" />

        <Label id="noSongsLabel" text="No songs available

Add songs to assets/songs/ folder"
               font="font:SmallSystemFont" color="0x90CAF9AA" horizAlign="center" visible="false" />
    </children>
</component>
