<?xml version="1.0" encoding="utf-8" ?>
<component name="SongSelect" extends="Group">
    <script type="text/brightscript" uri="pkg:/components/screens/SongSelect.brs" />

    <interface>
        <field id="songCatalog" type="assocarray" alwaysNotify="true" />
        <field id="selectedSong" type="assocarray" alwaysNotify="true" />
        <field id="action" type="string" alwaysNotify="true" />
    </interface>

    <children>
        <Rectangle id="bgBase" color="0xB0B0B0FF" />

        <Rectangle id="geoPoly1" color="0xC8C8C8FF" />
        <Rectangle id="geoPoly2" color="0x9E9E9EFF" />
        <Rectangle id="geoPoly3" color="0xBDBDBDFF" />
        <Rectangle id="geoPoly4" color="0xA8A8A8FF" />
        <Rectangle id="geoPoly5" color="0xD0D0D0FF" />
        <Rectangle id="geoPoly6" color="0x959595FF" />
        <Rectangle id="geoPoly7" color="0xC0C0C0FF" />
        <Rectangle id="geoPoly8" color="0xAAAAAA80" />

        <Group id="headerGroup">
            <Rectangle id="headerBg" color="0x1a1a1aEE" />
            <Rectangle id="headerAccent" color="0xFF1493FF" />
            <Label id="headerTitle" text="SONG SELECT" font="font:MediumBoldSystemFont"
                   color="0xFFFFFFFF" horizAlign="left" />
        </Group>

        <Group id="listPanel">
            <Group id="songListContainer" />

            <Label id="scrollUpIndicator" text="▲" font="font:SmallBoldSystemFont"
                   color="0xFF149388" horizAlign="center" visible="false" />
            <Label id="scrollDownIndicator" text="▼" font="font:SmallBoldSystemFont"
                   color="0xFF149388" horizAlign="center" visible="false" />
        </Group>

        <Group id="detailsPanel">
            <Rectangle id="detailsPanelBg" color="0x1a1a1aCC" />
            <Rectangle id="detailsPanelBorderLeft" color="0xFF1493FF" />

            <Group id="artworkGroup">
                <Rectangle id="artworkBg" color="0x2a2a2aFF" />
                <Label id="artworkPlaceholder" text="♪" font="font:LargeBoldSystemFont"
                       color="0xFF149966" horizAlign="center" vertAlign="center" />
            </Group>

            <Label id="detailTitle" text="SONG TITLE" font="font:LargeBoldSystemFont"
                   color="0xFFFFFFFF" />

            <Label id="detailArtist" text="Artist" font="font:SmallSystemFont"
                   color="0xAAAAAAFF" />

            <Group id="diffBadge">
                <Rectangle id="diffBadgeBg" color="0x2a2a2aFF" />
                <Rectangle id="diffBadgeBorder" color="0xFF6B35FF" />
                <Label id="diffBadgeLabel" text="DIFFICULTY" font="font:SmallestBoldSystemFont"
                       color="0xFFFFFFCC" horizAlign="center" vertAlign="center" />
                <Label id="diffBadgeValue" text="0" font="font:LargeBoldSystemFont"
                       color="0xFFFFFFFF" horizAlign="center" vertAlign="center" />
            </Group>

            <Group id="bestScoreRow">
                <Rectangle id="bestScoreBg" color="0x2a2a2aCC" />
                <Label id="bestScoreLabel" text="BEST SCORE" font="font:SmallestBoldSystemFont" color="0xAAAAAAFF" horizAlign="center" />
                <Label id="bestScoreValue" text="---" font="font:MediumBoldSystemFont" color="0xFF1493FF" horizAlign="center" />
            </Group>

            <Group id="durationRow">
                <Rectangle id="durationBg" color="0x2a2a2aCC" />
                <Label id="durationLabel" text="DURATION" font="font:SmallestBoldSystemFont" color="0xAAAAAAFF" horizAlign="center" />
                <Label id="durationValue" text="0:00" font="font:MediumBoldSystemFont" color="0xFFFFFFFF" horizAlign="center" />
            </Group>

            <Group id="difficultyRow">
                <Label id="difficultyLabel" text="" font="font:SmallSystemFont" color="0x888888FF" />
                <Label id="difficultyValue" text="" font="font:SmallSystemFont" color="0xFF1493FF" />
            </Group>

            <Group id="playButton">
                <Rectangle id="playBtnBg" color="0xFF1493FF" />
                <Rectangle id="playBtnHighlight" color="0xFF69B4AA" />
                <Label id="playBtnLabel" text="▶  PLAY" font="font:MediumBoldSystemFont"
                       color="0xFFFFFFFF" horizAlign="center" vertAlign="center" />
            </Group>

            <Group id="qrSection">
                <Label id="qrLabel" text="Scan to play on phone" font="font:SmallestSystemFont"
                       color="0x888888FF" horizAlign="center" />
                <Poster id="qrImage" uri="pkg:/images/qr_remote.png" />
            </Group>
        </Group>

        <Label id="instructions" text="↑↓ Navigate   |   OK Play   |   ← Back"
               font="font:SmallSystemFont" color="0x888888CC" horizAlign="center" />

        <Label id="noSongsLabel" text="No songs available

Add songs to assets/songs/ folder"
               font="font:SmallSystemFont" color="0xAAAAAAFF" horizAlign="center" visible="false" />
    </children>
</component>
